#!/usr/bin/env python3
"""img2video — real image-to-video via xAI grok-imagine-video.

Sends the ACTUAL image as the first frame (no text round-trip), so the subject
is preserved. Uses the existing grok login (OAuth token in ~/.grok/auth.json);
no separate API key needed.

Usage:
  img2video <image_path> "<motion/scene prompt>" [--duration N] [--resolution 720p|480p]
            [--aspect 16:9|9:16|1:1|4:3|3:4|3:2|2:3] [--out PATH] [--dry-run]

On success prints:  OK: <output_path>
"""
import sys
import os
import json
import base64
import time
import mimetypes
import argparse
import urllib.request
import urllib.error
from pathlib import Path

API = "https://api.x.ai/v1/videos/generations"
MODEL = "grok-imagine-video"


def _token() -> str:
    p = Path(os.path.expanduser("~/.grok/auth.json"))
    d = json.loads(p.read_text("utf-8"))
    scope = next(iter(d))
    val = d[scope]
    tok = val.get("key") if isinstance(val, dict) else val
    if not tok:
        raise SystemExit("ERROR: no auth token in ~/.grok/auth.json (run `grok login`)")
    return tok


def _call(method, url, tok, body=None, timeout=60):
    data = json.dumps(body).encode() if body is not None else None
    req = urllib.request.Request(url, data=data, method=method, headers={
        "Authorization": "Bearer " + tok, "Content-Type": "application/json"})
    try:
        with urllib.request.urlopen(req, timeout=timeout) as r:
            return r.status, r.read()
    except urllib.error.HTTPError as e:
        return e.code, e.read()


def main():
    ap = argparse.ArgumentParser(add_help=True)
    ap.add_argument("image", help="path to the source image (its content is preserved)")
    ap.add_argument("prompt", help="how the image should move / the scene")
    ap.add_argument("--duration", type=int, default=6, help="seconds (1-15, default 6)")
    ap.add_argument("--resolution", default="720p", choices=["480p", "720p"])
    ap.add_argument("--aspect", default=None)
    ap.add_argument("--out", default=None, help="output .mp4 path (default: <image>_video.mp4)")
    ap.add_argument("--dry-run", action="store_true", help="build the request but do not call the API")
    a = ap.parse_args()

    img = Path(a.image).expanduser()
    if not img.is_file():
        raise SystemExit(f"ERROR: image not found: {img}")
    mime = mimetypes.guess_type(str(img))[0] or "image/jpeg"
    if not mime.startswith("image/"):
        raise SystemExit(f"ERROR: not an image: {img} ({mime})")
    uri = f"data:{mime};base64," + base64.b64encode(img.read_bytes()).decode()

    body = {"model": MODEL, "prompt": a.prompt, "image": {"url": uri}}
    if a.duration:
        body["duration"] = a.duration
    if a.resolution:
        body["resolution"] = a.resolution
    if a.aspect:
        body["aspect_ratio"] = a.aspect

    out = Path(a.out).expanduser() if a.out else img.with_name(img.stem + "_video.mp4")
    n = 1
    while out.exists():
        out = img.with_name(f"{img.stem}_video_{n}.mp4")
        n += 1

    if a.dry_run:
        preview = dict(body)
        preview["image"] = {"url": uri[:48] + f"...<{len(uri)} chars base64>"}
        print("DRY-RUN request to", API)
        print(json.dumps(preview, ensure_ascii=False, indent=2))
        print("would write ->", out)
        return

    tok = _token()
    st, b = _call("POST", API, tok, body)
    if st != 200:
        raise SystemExit(f"ERROR submit ({st}): {b[:400].decode('utf-8', 'replace')}")
    rid = json.loads(b).get("request_id") or json.loads(b).get("id")
    if not rid:
        raise SystemExit(f"ERROR: no request_id: {b[:300].decode('utf-8', 'replace')}")
    print(f"submitted {rid} (duration={a.duration}s {a.resolution}) — generating…", flush=True)

    url = None
    start = time.time()
    while time.time() - start < 600:
        time.sleep(8)
        st, b = _call("GET", f"https://api.x.ai/v1/videos/{rid}", tok)
        txt = b.decode("utf-8", "replace") if isinstance(b, (bytes, bytearray)) else str(b)
        try:
            j = json.loads(txt)
        except Exception:
            continue
        # 202 = still generating; only 4xx/5xx are terminal. The GET returns 400 with a
        # moderation/error body (and NO "status" field) when the result is rejected — without
        # this check the loop would spin on status=None until the 600s timeout (the old bug).
        if st >= 400:
            low = txt.lower()
            if "moderation" in low or "rejected" in low or j.get("block_reason"):
                raise SystemExit("ERROR: BLOCKED — the generated video was rejected by "
                                 "content moderation. Try a less explicit motion prompt, a "
                                 "different seed frame, or 480p. " + txt[:200])
            raise SystemExit(f"ERROR: generation failed ({st}): {txt[:300]}")
        status = j.get("status")
        prog = j.get("progress")
        print(f"  status={status} progress={prog}", flush=True)
        if status in ("done", "completed"):
            url = (j.get("video") or {}).get("url") or j.get("url")
            break
        if status in ("failed", "expired"):
            raise SystemExit(f"ERROR: generation {status}: {json.dumps(j)[:400]}")
    if not url:
        raise SystemExit("ERROR: timed out waiting for the video")

    req = urllib.request.Request(url, headers={"Authorization": "Bearer " + tok})
    with urllib.request.urlopen(req, timeout=300) as r:
        out.write_bytes(r.read())
    print(f"OK: {out}")


if __name__ == "__main__":
    main()
