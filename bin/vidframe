#!/usr/bin/env python3
"""vidframe — extract a still frame from a video as a PNG (video -> image).

Usage:
  vidframe <video> [--at last|first|middle|<seconds>] [--out PATH]

Prints:  OK: <output_path>
"""
import argparse
import re
import subprocess
from pathlib import Path

FFMPEG = str(Path(__file__).resolve().parent / "ffmpeg")


def _duration(video):
    r = subprocess.run([FFMPEG, "-hide_banner", "-i", str(video)], capture_output=True, text=True)
    m = re.search(r"Duration:\s*(\d+):(\d+):(\d+\.\d+)", r.stderr)
    if m:
        h, mn, s = m.groups()
        return int(h) * 3600 + int(mn) * 60 + float(s)
    return None


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("video")
    ap.add_argument("--at", default="last", help="last | first | middle | <seconds>")
    ap.add_argument("--out", default=None)
    a = ap.parse_args()

    vid = Path(a.video).expanduser()
    if not vid.is_file():
        raise SystemExit(f"ERROR: video not found: {vid}")
    at = a.at.lower()
    tag = {"last": "_lastframe", "first": "_firstframe", "middle": "_midframe"}.get(at, "_frame")
    out = Path(a.out).expanduser() if a.out else vid.with_name(vid.stem + tag + ".png")
    n = 1
    while out.exists():
        out = vid.with_name(f"{vid.stem}{tag}_{n}.png")
        n += 1

    base = [FFMPEG, "-y", "-hide_banner", "-loglevel", "error"]
    if at == "first":
        cmd = base + ["-i", str(vid), "-frames:v", "1", str(out)]
    elif at == "last":   # reverse -> first frame = the EXACT last frame (sseof lands early)
        cmd = base + ["-i", str(vid), "-vf", "reverse", "-frames:v", "1", str(out)]
    elif at == "middle":
        d = _duration(vid) or 0
        cmd = base + ["-ss", str(d / 2), "-i", str(vid), "-frames:v", "1", str(out)]
    else:
        cmd = base + ["-ss", at, "-i", str(vid), "-frames:v", "1", str(out)]

    r = subprocess.run(cmd, capture_output=True, text=True)
    if not out.exists():  # fallback for 'last' on odd files: decode + reverse
        if at == "last":
            subprocess.run(base + ["-i", str(vid), "-vf", "reverse", "-frames:v", "1", str(out)],
                           capture_output=True, text=True)
        if not out.exists():
            raise SystemExit(f"ERROR: ffmpeg failed: {r.stderr[-400:]}")
    print(f"OK: {out}")


if __name__ == "__main__":
    main()
