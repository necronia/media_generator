# Grok Studio — example environment configuration.
#
# The app reads these from its PROCESS ENVIRONMENT (it does not auto-load this
# file). Copy it to `.env` (git-ignored) and load it one of these ways:
#   • systemd:  add  EnvironmentFile=%h/grok-studio/.env  to the service unit
#   • shell:    run  `set -a; source .env; set +a`  before launching uvicorn
# Every value below is the built-in default — uncomment/edit only what you need.

# ── Core ────────────────────────────────────────────────────────────────
# Path to the authenticated Grok CLI binary (must be on PATH or absolute).
GROK_WEB_GROK_BIN=grok

# Folder Grok reads/writes; the gallery watches it for new images/videos.
GROK_WEB_WORKSPACE=./workspace

# Grok model to run.
GROK_WEB_MODEL=grok-build

# ── Server bind ─────────────────────────────────────────────────────────
GROK_WEB_HOST=127.0.0.1
GROK_WEB_PORT=8799

# ── Auth ────────────────────────────────────────────────────────────────
# Require the built-in password gate. Set 0 when a gateway (e.g. Cloudflare
# Access) already authenticates the request.
GROK_WEB_REQUIRE_PASSWORD=1

# Fixed access password. Leave empty to auto-generate one on first run
# (printed to the console and saved to app/.password).
GROK_WEB_PASSWORD=

# ── Behavior / tuning ───────────────────────────────────────────────────
# Cap Grok's agent turns per request. Empty = no cap.
GROK_WEB_MAX_TURNS=

# Auto-remove byte-identical duplicate media from the workspace (1=on, 0=off).
GROK_WEB_DEDUPE=1

# Seconds with no Grok output before a run is abandoned.
GROK_WEB_INACTIVITY_TIMEOUT=600

# Gallery refresh: 0 = inotify filesystem watch, 1 = periodic polling
# (use 1 where inotify is unreliable, e.g. some network / 9p mounts).
GROK_WEB_POLL_WATCH=0
